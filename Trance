<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hypnotic Cyber Vortex</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            background: #030308;
            overflow: hidden;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            font-family: 'Segoe UI', sans-serif;
        }

        /* Hypnotic Outer Canvas Layer */
        .illusion-container {
            position: relative;
            width: 100vw;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: radial-gradient(circle, #050515 0%, #000000 100%);
        }

        /* Generated Spiral Ring Framework */
        .ring {
            position: absolute;
            border: 4px dashed #ff007f;
            border-radius: 50%;
            animation: swirl 8s linear infinite;
            box-shadow: 0 0 20px rgba(255, 0, 127, 0.3), inset 0 0 20px rgba(0, 255, 204, 0.2);
            box-sizing: border-box;
        }

        /* Alternating rings color inversion for deep optical contrast */
        .ring:nth-child(even) {
            border-color: #00ffcc;
            animation-direction: reverse;
            animation-duration: 6s;
        }

        /* Continuous Spinning Mathematical Matrix */
        @keyframes swirl {
            0% {
                transform: rotate(0deg) scale(1);
                opacity: 0.3;
            }
            50% {
                opacity: 0.9;
            }
            100% {
                transform: rotate(360deg) scale(0.05);
                opacity: 0.1;
            }
        }

        /* Overlay centerpiece target */
        .center-dot {
            position: absolute;
            width: 15px;
            height: 15px;
            background: #fff;
            border-radius: 50%;
            box-shadow: 0 0 25px #fff, 0 0 50px #ff007f, 0 0 100px #00ffcc;
            z-index: 100;
        }

        .title {
            position: absolute;
            top: 20px;
            color: #7a7a9a;
            font-size: 0.8rem;
            letter-spacing: 3px;
            text-transform: uppercase;
            pointer-events: none;
        }
    </style>
</head>
<body>

    <div class="title">Stare into the center vertex</div>
    
    <div class="illusion-container" id="vortex">
        <div class="center-dot"></div>
    </div>

    <script>
        const vortex = document.getElementById('vortex');
        const totalRings = 40; // Dense ring count creates a tightly-packed illusion pattern

        // Generate alternating concentric geometric rings dynamically
        for (let i = 0; i < totalRings; i++) {
            const ring = document.createElement('div');
            ring.className = 'ring';
            
            // Calculate decreasing sizes to simulate 3D depth perspective
            const size = 100 + (i * 25); 
            ring.style.width = size + 'px';
            ring.style.height = size + 'px';
            
            // Stagger the animations perfectly so they continuously march into the center
            ring.style.animationDelay = (i * 0.18) + 's';
            
            vortex.appendChild(ring);
        }
    </script>
</body>
</html>
